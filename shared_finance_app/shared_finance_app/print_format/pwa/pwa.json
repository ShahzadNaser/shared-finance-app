                <td> Less Adv Paid </td>\\n                        <td> Now being Request </td>\\n                        <td> Balance Payable </td>\\n                        <td> Remarks </td>\\n                    </tr>\\n                {% if doc.pay_to_party == 0 %}\\n                    {%- for row in doc.payment_request_item -%}\\n                        <tr style=\\\"border-color: #D3D3D3;\\\">\\n                            <td> {{ row.remarks or \\\" \\\" }} </td>\\n                            <td>  {{ frappe.utils.fmt_money((row.amount), currency=doc.currency)}} </td>\\n                            <td> {{ frappe.utils.fmt_money((row.less_advance_paid), currency=doc.currency)}}</td>\\n                            <td>  {{ frappe.utils.fmt_money((row.now_being_request), currency=doc.currency)}} </td>\\n                            <td>{{ frappe.utils.fmt_money((row.balance_payable), currency=doc.currency)}} </td>\\n                            {% if row.party_type == \\\"Supplier\\\" %}\\n                            <td>{{ row.party }}  </td>\\n                            {% else %}\\n                            <td>{{ row.account or \\\"\\\" }}  </td>\\n                             {% endif %}\\n                        </tr>\\n                    {%- endfor -%}\\n                {% endif %}\\n                    <tr style=\\\"border-color: #D3D3D3;\\\">\\n                    {% if doc.remark_ %}\\n                        <td> {{doc.remark_}} </td>\\n                    {% else %}\\n                        <td> Total amount </td>\\n                    {% endif %}\\n                        <td>  {{ frappe.utils.fmt_money(doc.grand_total, currency=doc.currency) }} </td>\\n                        <td>   {{ frappe.utils.fmt_money(doc.total_of_advance_paid, currency=doc.currency) }}</td>\\n                        <td>  {{ frappe.utils.fmt_money(doc.total_now_being_requested , currency=doc.currency) }} </td>\\n                        <td>   {{ frappe.utils.fmt_money(doc.total_balance, currency=doc.currency) }}</td>\\n                        <td>   </td>\\n                    </tr>\\n                \\n                </tbody>\\n        </table>\\n\\n    </div>\\n\\n    <div class=\\\"row\\\" >  \\n            <table style=\\\" border:solid 1px #D3D3D3;\\\">\\n                <tbody>\\n                    <tr style=\\\"height: auto; \\\">\\n                        <td rowspan=\\\"5\\\" style=\\\"width: 3%; width: 6.64%;border-right: solid 1px #D3D3D3;\\\">\\n                            PAYMENT MODE\\n                        </td>\\n                        {% if doc.wire_transfer %}\\n                        <td style=\\\"width: 16.2%;  text-align: center;     border-bottom: solid 1px #D3D3D3;\\\">\\n                            Wire Transfer : {{ frappe.utils.fmt_money(doc.wire_transfer, currency=doc.currency)   }} \\n                        </td>\\n                        {% endif %}\\n                    </tr>  \\n                    <tr style=\\\"height: auto; \\\">\\n                        {% if doc.fvg %}\\n                        <td style=\\\"width: 16.2%;  text-align: center;     border-bottom: solid 1px #D3D3D3;\\\">\\n                            Fvg, {{ doc.fvg or \\\"\\\" }}\\n                        </td>\\n                        {% endif %}\\n                    </tr>\\n                    <tr style=\\\"height: auto; \\\">\\n                    {% if doc.iban %}\\n                        <td style=\\\"width: 16.2%;  text-align: center;     border-bottom: solid 1px #D3D3D3;\\\">\\n                            IBAN:{{ doc.iban or \\\" \\\"}}\\n                        </td>\\n                    {% endif %}\\n                    </tr>\\n                    <tr style=\\\"height: auto; \\\">\\n                    {% if doc.through_cheque %}\\n                        <td style=\\\"width: 16.2%;  text-align: center;     border-bottom: solid 1px #D3D3D3;\\\">\\n                            Through Cheque :{{  frappe.utils.fmt_money(doc.through_cheque, currency=doc.currency)  }}\\n                        </td>\\n                    {% endif %}    \\n                    </tr>\\n                    <tr style=\\\"height: auto; \\\">\\n                    {% if doc.fvg1 %}\\n                        <td style=\\\"width: 16.2%;  text-align: center;     border-bottom: solid 1px #D3D3D3;\\\">\\n                            Fvg,{{ doc.fvg1 or \\\"\\\" }} \\n                        </td>\\n                    {% endif %}\\n                    </tr>\\n                </tbody>\\n            </table>\\n    </div>\\n\\n    <div class=\\\"row\\\" style=\\\" padding-top: 50px; border-width: 0px 1px 0px 1px; border-style: solid; border-color: #D3D3D3;\\\" >  \\n        <div class=\\\"col-xs-2\\\"  >\\n            <p>_____________</p>\\n            <p>PREPARED BY  </p>\\n        </div>\\n        <div class=\\\"col-xs-3\\\" style=\\\" text-align:center;\\\" >\\n            <p>__________________</p>\\n            <p>ACCOUNTING MANAGER  </p>\\n         </div>\\n        <div class=\\\"col-xs-2\\\" style=\\\" text-align:center;\\\" >\\n            <p>_____________</p>\\n            <p> DEPARTMENT HEAD (REQUESTEE)  </p>\\n       \\n        </div>\\n        <div class=\\\"col-xs-3\\\" style=\\\" text-align:center;\\\"  >\\n            <p>_____________</p>\\n            <p>CHIEF FINANCIAL OFFICER  </p>\\n            \\n        </div>\\n        <div class=\\\"col-xs-2\\\"  style=\\\" text-align:center;\\\" >\\n            <p>_____________</p>\\n            <p> FINAL APPROVAL  </p>\\n\\n        </div>\\n    </div>\\n        <div class=\\\"row\\\" style=\\\" text-align:left; border-width: 0px 1px 1px 1px; border-style: solid; border-color: #D3D3D3;\\\">  \\n            <div class=\\\"col-xs-12 borderright\\\"  >\\n            <p>&nbsp;</p>\\n            AMOUNT IN WORDS: {{ frappe.utils.money_in_words(doc.total_now_being_requested)| replace(\\\"SAR\\\",\\\"\\\") | replace(\\\"only\\\",\\\"\\\") | replace(\\\".\\\",\\\