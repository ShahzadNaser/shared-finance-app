 "format_data": "[{\"fieldname\": \"print_heading_template\", \"fieldtype\": \"Custom HTML\", \"options\": \"<div></div>\"}, {\"fieldtype\": \"Section Break\", \"label\": \"\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"_custom_html\", \"print_hide\": 0, \"label\": \"Custom HTML\", \"fieldtype\": \"HTML\", \"options\": \"<div class=\\\"row\\\" style=\\\"padding-left: 16px; padding-right: 16px;margin-left: 5px;width: 99.2221%;\\\">\\n\\n <div style=\\\"margin-top:8px;\\\">  \\n    <div class=\\\"row\\\" style=\\\" text-align:center; border-width: 1px 1px 0px 1px; border-style: solid; border-color: #D3D3D3;\\\">  \\n            <div class=\\\"col-xs-12 borderright\\\" style=\\\"background-color: #EBECF0\\\" >\\n            <h1>Payment Withdrawal Approval Sheet</h1>\\n            </div>\\n    </div>\\n    <div class=\\\"row\\\" style=\\\" text-align:left; border-width: 1px 1px 0px 1px; border-style: solid; border-color: #D3D3D3;\\\">  \\n            <div style=\\\"padding: 8px;\\\" >\\n            <b>POST BOX 4955  ALKHOBAR - 31952 SAUDI ARABIA </b>\\n            </div>\\n    </div>\\n    <div class=\\\"row\\\" style=\\\" border-width: 1px 1px 0px 1px; border-style: solid; border-color: #D3D3D3;\\\">  \\n            <div class=\\\"col-xs-2\\\" style=\\\"border-right: solid 1px !important; border-color:  #D3D3D3 !IMPORTANT;\\\" >\\n                <b>DATE</b>\\n            </div>\\n            <div class=\\\"col-xs-10 bderright\\\"   >\\n                {{ doc.transaction_date}}\\n            </div>\\n    </div>         \\n    <div class=\\\"row\\\" style=\\\" border-width: 1px 1px 0px 1px; border-style: solid; border-color: #D3D3D3;\\\">  \\n            <div class=\\\"col-xs-2 borderright\\\" style=\\\"border-right: solid 1px !important; line-height: 34px; border-color:  #D3D3D3 !IMPORTANT;\\\" >\\n                <b>REFERENCE</b>\\n            </div>\\n            <div class=\\\"col-xs-3 borderright\\\" style=\\\"border-right: solid 1px !important;  border-